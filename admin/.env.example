# Linky admin — required NEXT_PUBLIC_* env so the browser can call the
# Supabase edge functions. Both values are public-safe (anon key is the
# RLS-gated client key, never the service_role secret).
# Copy this file to .env.local and fill in the values from your Supabase
# project dashboard. The admin app does not boot without them.

NEXT_PUBLIC_SUPABASE_URL=https://fvvqgcsphwrmdlclnxcz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Drives the env pill in the topbar ("staging" / "production").
# Defaults to "staging" if unset.
NEXT_PUBLIC_ADMIN_ENV=staging
