{
  "name": "linky-driver",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "e2e:ios": "maestro test .maestro/flows",
    "doctor": "npx expo-doctor",
    "docs:lint": "node scripts/docs-lint.mjs",
    "animations:check": "node scripts/check-animations.mjs",
    "functions:check": "node scripts/check-edge-functions.mjs",
    "secrets:check": "node scripts/check-secrets.mjs",
    "store:check": "node scripts/check-store-readiness.mjs",
    "secrets:scan": "gitleaks dir --no-banner --redact || echo 'gitleaks not installed — skipping deep scan (brew install gitleaks). check-secrets still ran.'",
    "verify": "npm run format:check && npm run lint && npm run animations:check && npm run typecheck && npm run test && npm run docs:lint && npm run functions:check && npm run secrets:check",
    "new:feature": "node scripts/new-feature.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.58.0",
    "aes-js": "^3.1.2",
    "clsx": "^2.1.1",
    "expo": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "nativewind": "^4.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/aes-js": "^3.1.4",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.36.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^5.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3"
  },
  "optionalDependencies": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@emnapi/wasi-threads": "1.2.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "aes-js",
          "clsx",
          "tailwind-merge",
          "zod"
        ]
      }
    }
  }
}
