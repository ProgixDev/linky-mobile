{
  "$comment": "Project harness settings — versioned. Personal overrides go in .claude/settings.local.json (gitignored).",
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/protect-paths.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/post-edit-format.mjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run verify)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run docs:lint)",
      "Bash(npm run e2e*)",
      "Bash(npm run new:feature*)",
      "Bash(npx expo *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(eas credentials*)"
    ]
  }
}
