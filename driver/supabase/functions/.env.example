# Edge Function secrets — set with `supabase secrets set --env-file ...`.
# These live ONLY on the server; never in the app bundle or EXPO_PUBLIC_*.
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by the platform
# at runtime — you do NOT set them here. The service_role key bypasses RLS and
# must never leave the server.

# Shared secret you also paste into the RevenueCat dashboard Authorization header.
REVENUECAT_WEBHOOK_SECRET=generate-a-long-random-string
