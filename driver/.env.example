# Copy to .env (git-ignored). Only EXPO_PUBLIC_* vars reach the JS bundle.
# All vars are validated at startup by src/shared/lib/env.ts — the app
# fails fast with a readable error if something is missing or malformed.
#
# ⚠️  EXPO_PUBLIC_* is PLAINTEXT in the shipped bundle. Never put a secret here.
#     Real secrets (Supabase service_role, Stripe sk_, RevenueCat webhook secret)
#     live ONLY server-side: EAS secrets / Supabase Edge Function secrets.
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_APP_ENV=development

# Supabase — use the ANON / PUBLISHABLE key (safe to ship; RLS is the boundary).
# The service_role / sb_secret_ key must NEVER appear here (env.ts rejects it).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
